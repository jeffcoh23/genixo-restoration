# Copy to `keystore.properties` (gitignored) once you've generated the keystore
# via `mobile/scripts/generate-android-keystore.sh`.
#
# `storeFile` is resolved relative to `mobile/android/` (the gradle root project).
storeFile=keystore/genixo-upload.jks
storePassword=REPLACE_ME
keyAlias=genixo-upload
keyPassword=REPLACE_ME
