<h2 style="margin: 0 0 16px 0; font-size: 18px; font-weight: 600; color: #1a2b33;">New Login Request</h2>

<p style="margin: 0 0 16px 0; font-size: 14px; color: #3d5361; line-height: 1.5;">
  Someone has requested access to Genixo Restoration. Review it on the Users page — approving opens a prefilled invitation.
</p>

<table style="width: 100%; border-collapse: collapse; margin: 0 0 24px 0;">
  <tr>
    <td style="padding: 8px 0; font-size: 13px; color: #8899a4; width: 120px;">Name</td>
    <td style="padding: 8px 0; font-size: 13px; color: #1a2b33;"><%= @login_request.full_name %></td>
  </tr>
  <tr>
    <td style="padding: 8px 0; font-size: 13px; color: #8899a4;">Email</td>
    <td style="padding: 8px 0; font-size: 13px; color: #1a2b33;"><%= @login_request.email %></td>
  </tr>
  <% if @login_request.company_name.present? %>
  <tr>
    <td style="padding: 8px 0; font-size: 13px; color: #8899a4;">Company</td>
    <td style="padding: 8px 0; font-size: 13px; color: #1a2b33;"><%= @login_request.company_name %></td>
  </tr>
  <% end %>
  <% if @login_request.phone.present? %>
  <tr>
    <td style="padding: 8px 0; font-size: 13px; color: #8899a4;">Phone</td>
    <td style="padding: 8px 0; font-size: 13px; color: #1a2b33;"><%= @login_request.phone %></td>
  </tr>
  <% end %>
</table>

<% if @login_request.message.present? %>
<div style="margin: 0 0 24px 0; padding: 12px 16px; background-color: #f0f4f5; border-radius: 6px;">
  <p style="margin: 0; font-size: 13px; color: #3d5361; line-height: 1.6; white-space: pre-wrap;"><%= @login_request.message %></p>
</div>
<% end %>

<p style="margin: 0 0 24px 0;">
  <a href="<%= users_url %>" style="display: inline-block; padding: 10px 20px; background-color: #1a2b33; color: #ffffff; font-size: 14px; font-weight: 600; text-decoration: none; border-radius: 6px;">Review on Users page</a>
</p>

<p style="margin: 0; font-size: 12px; color: #8899a4;">
  No account has been created — nothing happens until you approve and send an invitation.
</p>
